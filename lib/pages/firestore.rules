rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    // Kullanıcının giriş yapıp yapmadığını kontrol eder.
    function isSignedIn() {
      return request.auth != null;
    }

    // Kullanıcının kendi dokümanına erişip erişmediğini kontrol eder.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // İki kullanıcının arkadaş olup olmadığını kontrol eder.
    function areFriends(userId1, userId2) {
      return exists(/databases/$(database)/documents/users/$(userId1)) &&
             userId2 in get(/databases/$(database)/documents/users/$(userId1)).data.friends;
    }

    // Bir kullanıcının diğerini engelleyip engellemediğini kontrol eder.
    function isBlocked(blockerId, blockedId) {
        return exists(/databases/$(database)/documents/users/$(blockerId)) &&
               blockedId in get(/databases/$(database)/documents/users/$(blockerId)).data.blockedUsers;
    }

    // --- Koleksiyon Kuralları ---

    // 'users' Koleksiyonu
    match /users/{userId} {
      // Herkes (giriş yapmış) bir kullanıcının profilini okuyabilir,
      // ancak sadece o kullanıcı sizi engellememişse.
      allow read: if isSignedIn() && !isBlocked(userId, request.auth.uid);

      // Bir kullanıcı sadece kendi profilini oluşturabilir.
      allow create: if isOwner(userId);

      // Bir kullanıcı sadece kendi profilini güncelleyebilir.
      // 'role', 'friends', 'createdAt', 'blockedUsers' gibi kritik alanların
      // istemci tarafından değiştirilmesini engelliyoruz.
      allow update: if isOwner(userId) &&
                       request.resource.data.keys().hasOnly(['name', 'surname', 'displayName', 'about', 'age', 'branch', 'profileImageUrl', 'fcmToken']);
                       
      // Kullanıcılar kendi hesaplarını silemez. (Genellikle bu işlem sunucu tarafında yönetilir)
      allow delete: if false;
    }

    // 'chats' Koleksiyonu
    match /chats/{chatId} {
      // Sadece sohbetin bir parçası olan kullanıcılar sohbet bilgilerini okuyabilir.
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;

      // Sohbet odası sadece mesaj gönderildiğinde oluşturulur/güncellenir,
      // bu yüzden doğrudan yazma izni vermiyoruz.
      allow write: if false;

      // 'messages' Alt Koleksiyonu
      match /messages/{messageId} {
        // Sadece sohbetin bir parçası olan kullanıcılar mesajları okuyabilir.
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;

        // Bir kullanıcı sadece kendi adına mesaj gönderebilir ve
        // alıcıyı engellememiş olmalıdır.
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         !isBlocked(request.auth.uid, request.resource.data.receiverId) &&
                         !isBlocked(request.resource.data.receiverId, request.auth.uid);
                         
        // Mesajlar sadece 'isRead' alanı için güncellenebilir ve bunu sadece alıcı yapabilir.
        allow update: if isSignedIn() &&
                         request.resource.data.receiverId == request.auth.uid &&
                         request.resource.data.isRead == true &&
                         !request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
                         
        // Mesajlar silinemez.
        allow delete: if false;
      }
    }

    // 'friend_requests' Koleksiyonu
    match /friend_requests/{requestId} {
      // Bir isteği sadece gönderen veya alıcı okuyabilir.
      allow read: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);

      // Bir kullanıcı sadece kendi adına istek gönderebilir.
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;

      // Bir isteği sadece alıcı güncelleyebilir ve sadece 'status' alanını 'declined' olarak değiştirebilir.
      // 'accepted' durumu sadece Cloud Function tarafından yönetilir.
      allow update: if isSignedIn() && request.auth.uid == resource.data.receiverId &&
                       request.resource.data.status == 'declined';

      // Bir isteği sadece gönderen veya alıcı silebilir.
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
    }
  }
}